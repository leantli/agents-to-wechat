{
  "name": "agents-to-wechat",
  "version": "0.1.0",
  "description": "Connect Codex to WeChat private chats through a Node.js bridge with managed codex-acp sessions.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agents-to-wechat": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leantli/agents-to-wechat.git"
  },
  "homepage": "https://github.com/leantli/agents-to-wechat#readme",
  "bugs": {
    "url": "https://github.com/leantli/agents-to-wechat/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "leantli <liyantao0063@gmail.com>",
  "contributors": [],
  "keywords": [
    "wechat",
    "weixin",
    "wx",
    "wc",
    "codex",
    "agent",
    "chatbot",
    "ai",
    "assistant",
    "wechat-bot",
    "bridge",
    "acp",
    "cli"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "check": "tsc --noEmit",
    "verify": "npm run lint && npm test && npm run check",
    "changeset": "changeset",
    "version-packages": "changeset version && npm install --package-lock-only",
    "release:preflight": "npm run verify && npm run format:check && npm run build && npm pack --dry-run && node dist/index.js --help && node dist/index.js doctor --help",
    "cli": "node --import tsx src/index.ts",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "npm run lint && npm test && npm run check && npm run build",
    "version": "npm run lint && npm test && npm run check"
  },
  "dependencies": {
    "@zed-industries/codex-acp": "0.10.0",
    "commander": "^13.1.0",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.15",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitest/coverage-v8": "^3.2.4",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.2.4"
  }
}
